        "text_fXKGGQ": {
          "type": "text",
          "settings": {
            "title": "Nährtwertangaben",
            "text": "<p>{{ product.metafields.custom.accordion_text_2.value }}<\/p>"
          }
        },
        "text_Kr3LNL": {
          "type": "text",
          "settings": {
            "title": "Nahrungsergänzungsmittel",
            "text": "<p>Nahrungsergänzungsmittel sind kein Ersatz für eine abwechslungsreiche, ausgewogene Ernährung und eine gesunde Lebensweise. Die empfohlene tägliche Verzehrsmenge darf nicht überschritten werden. Immer außerhalb der Reichweite von Kindern aufbewahren. Die bereitgestellte Information ist nicht als Ersatz für Empfehlungen Ihres Arztes oder anderer medizinischer Fachkräfte gedacht. Es ist auch keine Heilaussage oder Aufforderung zur Selbstmedikation.<\/p>"
          }
